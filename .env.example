# Billy — gabarit de configuration. Copier en `.env` (jamais committé).
# Aucune clé en dur dans le code : tout passe par ces variables.

PORT=3000
NODE_ENV=development

# --- Moteur conversationnel (LLM) ---
# Fournisseur recommandé : Claude (Anthropic). Modèle par défaut : claude-opus-4-8.
ANTHROPIC_API_KEY=
BILLY_LLM_MODEL=claude-opus-4-8

# --- Speech-to-text (STT) temps réel ---
STT_PROVIDER=
STT_API_KEY=

# --- Text-to-speech (TTS) — voix douce de Billy ---
TTS_PROVIDER=
TTS_API_KEY=
TTS_VOICE_ID=

# --- Sécurité / données ---
# Clé de chiffrement au repos (si enregistrement activé). 32 octets en base64.
DATA_ENCRYPTION_KEY=
# Enregistrement désactivé par défaut (minimisation RGPD). N'activer qu'avec base légale.
ENABLE_RECORDING=false
