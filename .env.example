# Billy — gabarit de configuration. Copier en `.env` (jamais committé).
# Aucune clé en dur dans le code : tout passe par ces variables.

PORT=3000
HTTPS_PORT=3443
NODE_ENV=development

# --- Voix en direct (TTS) — endpoint /api/tts ---
# Si ces 2 variables sont définies, Billy parle avec la vraie voix (ElevenLabs) EN DIRECT,
# partout (séance temps réel incluse). Sinon, le navigateur lit le texte (gratuit).
# Voix « Chloé » de la démo = à recréer/choisir côté ElevenLabs (coller l'ID ici).
ELEVENLABS_API_KEY=
ELEVENLABS_VOICE_ID=

# --- Moteur conversationnel (LLM) ---
# Fournisseur recommandé : Claude (Anthropic). Modèle par défaut : claude-haiku-4-5
# (le sélecteur ne fait que CHOISIR une réplique → Haiku suffit et coûte ~5x moins qu'Opus).
ANTHROPIC_API_KEY=
BILLY_LLM_MODEL=claude-haiku-4-5

# --- Speech-to-text (STT) temps réel ---
STT_PROVIDER=
STT_API_KEY=

# --- Text-to-speech (TTS) — voix douce de Billy ---
TTS_PROVIDER=
TTS_API_KEY=
TTS_VOICE_ID=

# --- Sécurité / données ---
# Clé de chiffrement au repos (si enregistrement activé). 32 octets en base64.
DATA_ENCRYPTION_KEY=
# Enregistrement désactivé par défaut (minimisation RGPD). N'activer qu'avec base légale.
ENABLE_RECORDING=false
